PORT=5000
JWT_SECRET=change_this_to_a_long_random_secret
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/society_management?retryWrites=true&w=majority
APP_BASE_URL=http://localhost:5173
MAIL_MODE=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=SocietyOS <no-reply@societyos.com>
SMTP_FROM_EMAIL=SocietyOS <no-reply@societyos.com>
EMAIL_FROM=SocietyOS <no-reply@societyos.com>
SMS_ENABLED=false
SMS_PROVIDER=twilio
SMS_DEFAULT_COUNTRY_CODE=+91
SMS_OTP_TEMPLATE=Your SocietyOS OTP is {{OTP}}. It expires in 5 minutes.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
